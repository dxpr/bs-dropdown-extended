{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*", "src/js/*"]
    }
  },
  "include": [
    "src/js/**/*.js",
    "src/js/**/*.ts",
    "eslint.config.js"
  ],
  "exclude": [
    "node_modules",
    "venv",
    "dist"
  ]
} 